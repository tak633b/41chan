# =============================================
# 41ch — 環境変数設定
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env
# =============================================

# --- LLMバックエンド選択 ---
# ollama: ローカルLLM（無料・プライベート）
# zai: ZAI GLM-5（クラウド・高品質）
# openrouter: OpenRouter経由の各種モデル
ORACLE_LLM_BACKEND=ollama

# --- ZAI設定 (BACKEND=zai のとき使用) ---
# ZAI Coding Plan のAPIキー（https://z.ai で取得）
ORACLE_ZAI_API_KEY=your_zai_api_key_here
# モデル名: glm-5 / glm-4-plus / glm-4-flash
ORACLE_ZAI_MODEL=glm-5

# --- Ollama設定 (BACKEND=ollama のとき使用) ---
# モデル名: qwen3.5:9b（推奨）/ qwen3.5:4b / llama3.2:3b
ORACLE_OLLAMA_MODEL=qwen3.5:9b

# --- OpenRouter設定 (BACKEND=openrouter のとき使用) ---
# OpenRouter APIキー（https://openrouter.ai で取得）
OPENROUTER_API_KEY=your_openrouter_api_key_here
# モデル名
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
