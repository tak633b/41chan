# =============================================
# 41chan — Environment Variables
# Copy this file to .env and set the values
# cp .env.example .env
# =============================================

# --- LLM Backend Selection ---
# ollama: Local LLM (free, private)
# zai: ZAI GLM-5 (cloud, high quality)
# openrouter: Various models via OpenRouter
ORACLE_LLM_BACKEND=ollama

# --- ZAI Settings (used when BACKEND=zai) ---
# API key from ZAI Coding Plan (get at https://z.ai)
ORACLE_ZAI_API_KEY=your_zai_api_key_here
# Model name: glm-5 / glm-4-plus / glm-4-flash
ORACLE_ZAI_MODEL=glm-5

# --- Ollama Settings (used when BACKEND=ollama) ---
# Model name: qwen3.5:9b (recommended) / qwen3.5:4b / llama3.2:3b
ORACLE_OLLAMA_MODEL=qwen3.5:9b

# --- OpenRouter Settings (used when BACKEND=openrouter) ---
# OpenRouter API key (get at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model name
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
